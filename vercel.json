{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/users/([^/]+)",
      "dest": "/api/users/[id].js"
    },
    {
      "src": "/api/robots/([^/]+)",
      "dest": "/api/robots/[id].js"
    },
    {
      "src": "/api/licenses/([^/]+)",
      "dest": "/api/licenses/[id].js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/(.*\\.(?:css|js|png|jpg|jpeg|svg|ico))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
